{
    "EXE": [
        "mkdir -p tests dist"
    ],
    "source/tests/*.js": "tests -plugins=malta-jest[argz:'--rootDir=.']",
    "source/tests/*.html": "tests",
    "source/*.md": ".",
    "source/index.js": "dist -plugins=malta-jest[argz:'--rootDir=.']...malta-header-comment[name:\"source/header.txt\"] -vars=source/vars.json"
}